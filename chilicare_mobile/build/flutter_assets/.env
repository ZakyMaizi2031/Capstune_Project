# ==========================================
# CHILICARE FRONTEND CONFIGURATION (FIX)
# ==========================================

# Nama Aplikasi yang muncul di sistem
APP_NAME=ChiliCare

# URL API BACKEND (Pilih salah satu sesuai device)
# ------------------------------------------
# A. Gunakan IP ini jika pakai EMULATOR ANDROID:
# BASE_URL=http://10.0.2.2:8000
# Gunakan localhost jika menjalankan di Chrome pada laptop yang sama dengan Backend
BASE_URL=http://localhost:8000
# B. Gunakan IP ini jika pakai HP FISIK (Ganti 192.168.x.x dengan IP Laptop Anda):
# BASE_URL=http://192.168.1.10:8000

# C. Gunakan ini jika Backend sudah ONLINE/HOSTING:
# BASE_URL=https://api.chilicare.id
# ------------------------------------------

# API Key (Opsional, untuk standar keamanan industri)
API_KEY=CHILICARE_SECRET_KEY_2024

# Versi Build
VERSION=1.0.0